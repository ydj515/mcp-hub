{
  "mcpServers": {
    "mcp-hub-api-finder": {
      "command": "npx",
      "args": ["-y", "mcp-hub", "stdio", "api-finder"],
      "env": {
        "PUBLIC_DATA_API_KEY": "${PUBLIC_DATA_API_KEY}"
      }
    },
    "mcp-hub-shortcuts": {
      "command": "npx",
      "args": ["-y", "mcp-hub", "stdio", "shortcuts"],
      "env": {}
    },
    "mcp-hub-mysql": {
      "command": "npx",
      "args": ["-y", "mcp-hub", "stdio", "mysql"],
      "env": {
        "MYSQL_URL": "${MYSQL_URL}"
      }
    },
    "mcp-hub-postgres": {
      "command": "npx",
      "args": ["-y", "mcp-hub", "stdio", "postgres"],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    }
  }
}
