{
  "mcpServers": {
    "mcp-hub-api-finder-remote": {
      "type": "http",
      "url": "https://mcp.example.com/mcp/api-finder",
      "headers": {
        "Authorization": "Bearer ${MCP_HUB_TOKEN}"
      }
    },
    "mcp-hub-shortcuts-remote": {
      "type": "http",
      "url": "https://mcp.example.com/mcp/shortcuts",
      "headers": {
        "Authorization": "Bearer ${MCP_HUB_TOKEN}"
      }
    },
    "mcp-hub-mysql-remote": {
      "type": "http",
      "url": "https://mcp.example.com/mcp/mysql",
      "headers": {
        "Authorization": "Bearer ${MCP_HUB_TOKEN}"
      }
    },
    "mcp-hub-postgres-remote": {
      "type": "http",
      "url": "https://mcp.example.com/mcp/postgres",
      "headers": {
        "Authorization": "Bearer ${MCP_HUB_TOKEN}"
      }
    }
  }
}
