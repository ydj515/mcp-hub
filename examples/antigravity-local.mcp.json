{
  "mcpServers": {
    "mcp-hub-api-finder": {
      "command": "node",
      "args": [
        "<mcp-hub-repo>/packages/cli/dist/index.js",
        "stdio",
        "api-finder"
      ],
      "env": {
        "PUBLIC_DATA_API_KEY": "${PUBLIC_DATA_API_KEY}"
      }
    },
    "mcp-hub-shortcuts": {
      "command": "node",
      "args": [
        "<mcp-hub-repo>/packages/cli/dist/index.js",
        "stdio",
        "shortcuts"
      ],
      "env": {}
    },
    "mcp-hub-mysql": {
      "command": "node",
      "args": ["<mcp-hub-repo>/packages/cli/dist/index.js", "stdio", "mysql"],
      "env": {
        "MYSQL_URL": "${MYSQL_URL}"
      }
    },
    "mcp-hub-postgres": {
      "command": "node",
      "args": [
        "<mcp-hub-repo>/packages/cli/dist/index.js",
        "stdio",
        "postgres"
      ],
      "env": {
        "POSTGRES_URL": "${POSTGRES_URL}"
      }
    },
    "mcp-hub-redis": {
      "command": "node",
      "args": ["<mcp-hub-repo>/packages/cli/dist/index.js", "stdio", "redis"],
      "env": {
        "REDIS_URL": "${REDIS_URL}"
      }
    },
    "mcp-hub-docker": {
      "command": "node",
      "args": ["<mcp-hub-repo>/packages/cli/dist/index.js", "stdio", "docker"],
      "env": {
        "DOCKER_ENABLE_WRITE_TOOLS": "${DOCKER_ENABLE_WRITE_TOOLS}",
        "DOCKER_ALLOWED_CONTAINERS": "${DOCKER_ALLOWED_CONTAINERS}",
        "DOCKER_ALLOWED_NETWORKS": "${DOCKER_ALLOWED_NETWORKS}",
        "DOCKER_ALLOWED_VOLUMES": "${DOCKER_ALLOWED_VOLUMES}",
        "DOCKER_COMPOSE_PROJECTS": "${DOCKER_COMPOSE_PROJECTS}"
      }
    },
    "mcp-hub-gitlab": {
      "command": "node",
      "args": ["<mcp-hub-repo>/packages/cli/dist/index.js", "stdio", "gitlab"],
      "env": {
        "GITLAB_TOKEN": "${GITLAB_TOKEN}",
        "GITLAB_URL": "${GITLAB_URL}",
        "GITLAB_ENABLE_WRITE_TOOLS": "${GITLAB_ENABLE_WRITE_TOOLS}"
      }
    }
  }
}
