{
  "mcpServers": {
    "mcp-hub-api-finder": {
      "command": "npx",
      "args": ["-y", "mcp-hub", "stdio", "api-finder"],
      "env": {
        "PUBLIC_DATA_API_KEY": "${PUBLIC_DATA_API_KEY}"
      }
    },
    "mcp-hub-shortcuts": {
      "command": "npx",
      "args": ["-y", "mcp-hub", "stdio", "shortcuts"],
      "env": {}
    },
    "mcp-hub-mysql": {
      "command": "npx",
      "args": ["-y", "mcp-hub", "stdio", "mysql"],
      "env": {
        "MYSQL_URL": "${MYSQL_URL}"
      }
    },
    "mcp-hub-postgres": {
      "command": "npx",
      "args": ["-y", "mcp-hub", "stdio", "postgres"],
      "env": {
        "POSTGRESQL_URL": "${POSTGRESQL_URL}"
      }
    },
    "mcp-hub-redis": {
      "command": "npx",
      "args": ["-y", "mcp-hub", "stdio", "redis"],
      "env": {
        "REDIS_URL": "${REDIS_URL}"
      }
    },
    "mcp-hub-docker": {
      "command": "npx",
      "args": ["-y", "mcp-hub", "stdio", "docker"],
      "env": {
        "DOCKER_ENABLE_WRITE_TOOLS": "${DOCKER_ENABLE_WRITE_TOOLS}",
        "DOCKER_ALLOWED_CONTAINERS": "${DOCKER_ALLOWED_CONTAINERS}",
        "DOCKER_ALLOWED_NETWORKS": "${DOCKER_ALLOWED_NETWORKS}",
        "DOCKER_ALLOWED_VOLUMES": "${DOCKER_ALLOWED_VOLUMES}",
        "DOCKER_COMPOSE_PROJECTS": "${DOCKER_COMPOSE_PROJECTS}"
      }
    },
    "mcp-hub-gitlab": {
      "command": "npx",
      "args": ["-y", "mcp-hub", "stdio", "gitlab"],
      "env": {
        "GITLAB_TOKEN": "${GITLAB_TOKEN}",
        "GITLAB_URL": "${GITLAB_URL}",
        "GITLAB_ENABLE_WRITE_TOOLS": "${GITLAB_ENABLE_WRITE_TOOLS}"
      }
    }
  }
}
