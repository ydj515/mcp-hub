{
  "mcpServers": {
    "pg-production": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "/Users/dongjin/tools/mcp-server/database/pg-mcp",
        "python",
        "-m",
        "pg_mcp.server"
      ],
      "env": {
        "DATABASE_URL": "postgresql://mcp_readonly:pw@prod-host:5432/myapp_prod",
        "MAX_ROWS": "100",
        "ALLOWED_SCHEMAS": "public"
      }
    },
    "pg-staging": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "/Users/dongjin/tools/mcp-server/database/pg-mcp",
        "python",
        "-m",
        "pg_mcp.server"
      ],
      "env": {
        "DATABASE_URL": "postgresql://mcp_readonly:pw@staging-host:5432/myapp_staging",
        "MAX_ROWS": "500",
        "ALLOWED_SCHEMAS": "public,staging"
      }
    }
  }
}
